NODE_ENV=development
PORT=5000
APP_NAME=Cyber Rakhwala API
APP_URL=http://localhost:5000
OPENAPI_SERVER_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
DNS_SERVERS=1.1.1.1,8.8.8.8
DEBUG_PANEL_ENABLED=true

MONGODB_URI=mongodb://127.0.0.1:27017/cyber-rakhwala

JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_ISSUER=cyber-rakhwala
JWT_AUDIENCE=cyber-rakhwala-web

COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

ADMIN_PANEL_PATH=deepaklogin
ADMIN_ALLOW_LEGACY_ROUTE=false

ENABLE_DEMO_AUTH=false
DEMO_PASSWORD=change-me-before-sharing
SEED_DEMO_USERS=false

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_NAME=Cyber Rakhwala
EMAIL_FROM_ADDRESS=no-reply@example.com

UPLOAD_STORAGE=local
UPLOAD_LOCAL_PATH=./src/uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

RECAPTCHA_SECRET_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=

DEFAULT_CURRENCY=INR
TRIAL_DAYS=7

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20
SEARCH_RATE_LIMIT_MAX=60

FEATURE_ENABLE_CHATBOT=true
FEATURE_ENABLE_DATASET_SEARCH=true
FEATURE_ENABLE_PROVIDER_CONNECTORS=true
FEATURE_ENABLE_THREAT_SIMULATOR=true

LOG_LEVEL=info

# Optional provider credentials.
# Most providers should still be configured from Admin > Providers so they can be
# enabled, disabled, rotated, and reassigned without redeploying the backend.

HIBP_API_KEY=
IPINFO_API_KEY=
SECURITYTRAILS_API_KEY=
VIRUSTOTAL_API_KEY=
SHODAN_API_KEY=
ABUSEIPDB_API_KEY=
ABSTRACT_PHONE_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
HUNTER_API_KEY=
EMAILREP_API_KEY=
CLOUDFLARE_API_TOKEN=
MAPBOX_API_KEY=
GOOGLE_MAPS_API_KEY=
